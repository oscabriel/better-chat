# Copy this file to .env.dev for development environment
# Copy this file to .env.prod for production environment

# The alchemy.run.ts file automatically loads the correct environment file based on the ALCHEMY_STAGE environment variable

# URL of the app frontend
# If using a custom domain, set this to that origin (e.g. "https://chat.example.com")
# Otherwise use your web worker URL.
CORS_ORIGIN="http://localhost:3001"

# Public origin for Better Auth (no path, no /api)
# If using a custom domain + Cloudflare route "/api/*", set to the SAME origin
# as your website: e.g. "https://chat.example.com"
# If using a separate Workers.dev domain for the API, set that host instead.
BETTER_AUTH_URL="http://localhost:3000"

BETTER_AUTH_SECRET="change-this-secret"

GOOGLE_GENERATIVE_AI_API_KEY="change-this-key"
