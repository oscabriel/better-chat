# Copy this file to .env.dev for development environment
# Copy this file to .env.prod for production environment

# The alchemy.run.ts file automatically loads the correct environment file based on the ALCHEMY_STAGE environment variable

# URL of the app frontend
# If using a custom domain, set this to that origin (e.g. "https://chat.example.com")
# Otherwise use your web worker URL.
CORS_ORIGIN="http://localhost:3001"

# Public origin for Better Auth (no path, no /api)
# If using a custom domain + Cloudflare route "/api/*", set to the SAME origin
# as your website: e.g. "https://chat.example.com"
# If using a separate Workers.dev domain for the API, set that host instead.
BETTER_AUTH_URL="http://localhost:3000"

BETTER_AUTH_SECRET="change-this-secret"

# Encryption key for sensitive user data (API keys, tokens)
# Generate a secure random key: openssl rand -base64 32
# IMPORTANT: Keep this secret and never commit it to version control
ENCRYPTION_KEY="generate-a-secure-random-key-here"

# AI SDK v5 Configuration
AI_SDK_VERSION="5.0.55"
DEFAULT_MODEL="google:gemini-2.0-flash"
PREMIUM_MODELS_ENABLED="true"
MCP_SERVERS_ENABLED="true"

# Provider API Keys for App-Provided Free Models
OPENAI_API_KEY="your-openai-key-for-free-models"
GOOGLE_GENERATIVE_AI_API_KEY="your-google-key-for-free-models"
LLAMA_API_KEY="your-llama-key-for-free-models"

# Legacy/Optional Provider Keys
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""

# MCP Server Configuration (Pre-configured)
MCP_CONTEXT7_URL="https://mcp.context7.com/sse"
MCP_CLOUDFLARE_URL="https://docs.mcp.cloudflare.com/sse"
